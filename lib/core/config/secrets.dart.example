/// Copy to `secrets.dart` (gitignored) or pass via `--dart-define`.
///
/// flutter run \
///   --dart-define=CONVEX_URL=https://your-deployment.convex.cloud \
///   --dart-define=CONVEX_DEPLOY_KEY=your_deploy_key
class Secrets {
  Secrets._();

  static const String convexUrl = String.fromEnvironment(
    'CONVEX_URL',
    defaultValue: '',
  );

  static const String convexDeployKey = String.fromEnvironment(
    'CONVEX_DEPLOY_KEY',
    defaultValue: '',
  );

  static bool get hasConvex =>
      convexUrl.isNotEmpty && convexDeployKey.isNotEmpty;
}
