# ──────────────────────────────────────────────────────────
# Convex environment for ProteqMe
# Copy this file to `.env.local` and fill in real values.
# ──────────────────────────────────────────────────────────

# Written automatically by `npx convex dev` on first run.
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Needed by the Flutter app (`--dart-define`).
# Get from: https://dashboard.convex.dev → your project → Settings → Deploy Keys
# Use a "Deployment Key" for dev, or a "Production Deploy Key" for prod.
CONVEX_DEPLOY_KEY=convex-deployment-key-here
